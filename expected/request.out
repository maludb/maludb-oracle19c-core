(1 row)

SELECT mc_stub_process(:request_id) AS response_id;
 response_id 
-------------
           1
(1 row)

SELECT request_status(:request_id) AS final_status;
 final_status 
--------------
 succeeded
(1 row)

SELECT status, output_text, output_hash, adapter_name
FROM get_response(:request_id);
