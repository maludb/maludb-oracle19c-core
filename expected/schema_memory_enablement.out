SELECT s.owner_schema, s.server_name, t.tool_name
FROM maludb_core.malu$mc2db_server s
JOIN maludb_core.malu$mc2db_tool t
  ON t.owner_schema = s.owner_schema
 AND t.server_id = s.server_id
