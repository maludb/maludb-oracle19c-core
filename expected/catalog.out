SET search_path TO maludb_core, pg_catalog;
SELECT count(*) AS catalog_tables
FROM pg_class c
JOIN pg_namespace n ON n.oid = c.relnamespace
WHERE n.nspname = 'maludb_core'
  AND c.relkind = 'r'
  AND c.relname LIKE 'malu$%';
 catalog_tables 
----------------
            152
(1 row)

