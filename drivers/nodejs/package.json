{
  "name": "@maludb/client",
  "version": "0.1.0",
  "description": "Node.js / TypeScript driver for MaluDB — a memory DBMS on PostgreSQL",
  "license": "PostgreSQL",
  "author": "Edward Honour <edward.honour@gmail.com>",
  "homepage": "https://github.com/edwardhonour/maludb-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/edwardhonour/maludb-core.git",
    "directory": "drivers/nodejs"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx test/*.test.ts",
    "example": "node --import tsx examples/01-ingest-to-replay.ts"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "postgresql",
    "memory",
    "llm",
    "rag",
    "knowledge",
    "audit",
    "maludb"
  ]
}
