{
    "name": "maludb/client",
    "description": "PHP driver for MaluDB — a memory DBMS on PostgreSQL.",
    "type": "library",
    "license": "PostgreSQL",
    "authors": [
        { "name": "Edward Honour", "email": "edward.honour@gmail.com" }
    ],
    "homepage": "https://github.com/edwardhonour/maludb-core",
    "keywords": ["postgresql", "memory", "llm", "rag", "knowledge", "audit", "maludb"],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MaluDB\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaluDB\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
