# Sample environment for maludb-restd.
# Source from a systemd EnvironmentFile= drop-in or shell rc file.

MALUDB_RESTD_DB=maludb
MALUDB_RESTD_HOST=/var/run/postgresql
MALUDB_RESTD_USER=maludb_restd
# MALUDB_RESTD_PORT=5432
# MALUDB_RESTD_PASSWORD=

MALUDB_RESTD_HOST_BIND=127.0.0.1
MALUDB_RESTD_PORT_BIND=5331
MALUDB_RESTD_LOG_LEVEL=INFO
